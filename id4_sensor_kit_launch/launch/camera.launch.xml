<launch>
  <arg name="launch_driver" default="true"/>

  <!-- Relay all 8 cameras from /cameraX/ to /sensing/camera/cameraX/ -->
  <node pkg="topic_tools" exec="relay" name="camera0_image_relay" output="log">
    <param name="input_topic"  value="/camera0/image_raw/compressed"/>
    <param name="output_topic" value="/sensing/camera/camera0/image_raw/compressed"/>
    <param name="type" value="sensor_msgs/msg/CompressedImage"/>
  </node>
  <node pkg="topic_tools" exec="relay" name="camera0_info_relay" output="log">
    <param name="input_topic"  value="/camera0/camera_info"/>
    <param name="output_topic" value="/sensing/camera/camera0/camera_info"/>
    <param name="type" value="sensor_msgs/msg/CameraInfo"/>
  </node>

